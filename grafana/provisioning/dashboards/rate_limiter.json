{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(ratelimiter_decisions_total[1m])",
          "legendFormat": "{{decision}} - {{limit_type}}",
          "refId": "A"
        }
      ],
      "title": "Rate Limit Decisions (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ratelimiter_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p95 latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(ratelimiter_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p99 latency",
          "refId": "B"
        }
      ],
      "title": "Rate Limiter Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "text": "CLOSED ✅" },
                "1": { "text": "OPEN 🔴" },
                "2": { "text": "HALF-OPEN 🟡" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 },
              { "color": "yellow", "value": 2 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "ratelimiter_circuit_breaker_state",
          "legendFormat": "Circuit Breaker",
          "refId": "A"
        }
      ],
      "title": "Circuit Breaker State",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(gateway_requests_total[1m])",
          "legendFormat": "{{method}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Gateway Requests (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "increase(ratelimiter_redis_errors_total[5m])",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "title": "Redis Errors (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(increase(ratelimiter_decisions_total{decision='denied'}[5m]))",
          "legendFormat": "Denied",
          "refId": "A"
        }
      ],
      "title": "Denied Requests (5m)",
      "type": "stat"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["rate-limiter", "api-gateway"],
  "title": "Rate Limiter Dashboard",
  "uid": "rate-limiter-dashboard",
  "version": 1
}
